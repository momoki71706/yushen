PORT=3001
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-5

# Web Push (proactive messages) — generate once with:
#   node -e "console.log(require('web-push').generateVAPIDKeys())"
# and keep the same pair forever; regenerating invalidates every existing
# subscription and everyone has to re-enable notifications.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
